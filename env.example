# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_DISCORD_ID="your-discord-app-client-id"
AUTH_DISCORD_SECRET="your-discord-app-client-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Main Discord Server (104th) ─────────────────────────────────────────────
DISCORD_GUILD_ID="your-main-guild-id"

# Art Team tier role IDs — assign the correct role ID for each tier
DISCORD_HEAD_ART_TEAM_ROLE_ID="role-id-for-head-of-art-team"
DISCORD_SENIOR_ART_TEAM_ROLE_ID="role-id-for-senior-art-team"
DISCORD_PRIMARY_ART_TEAM_ROLE_ID="role-id-for-primary-art-team"
DISCORD_RESERVE_ART_TEAM_ROLE_ID="role-id-for-reserve-art-team"
DISCORD_SF_ART_TEAM_ROLE_ID="role-id-for-sf-art-team-clearance"

# Custom helmet access — comma-separated list of rank role IDs that can enable
# the Custom Elements toggle in the request form (e.g. SGM+, SL+).
# Leave blank to allow all members to use it.
DISCORD_CUSTOM_HELMET_ROLE_IDS="role-id-1,role-id-2"

# Active member check — user must have at least one of these roles to sign in.
# Company roles (e.g. Ares Company, Reaper Company, etc.)
DISCORD_COMPANY_ROLE_IDS="role-id-1,role-id-2,role-id-3"

# Staff roles — staff bypass the company role requirement
DISCORD_STAFF_ROLE_IDS="role-id-1,role-id-2"

# Evidence webhook — submissions are posted to this channel
DISCORD_EVIDENCE_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# ─── KMC Server ──────────────────────────────────────────────────────────────
# Used to check qualification-specific decal eligibility
KMC_GUILD_ID="your-kmc-guild-id"

# Add KMC role IDs here as needed for qual-specific decal checks.
# These are available on session as session.user.kmcRoles[]
# and can be cross-referenced against decal requirements in custom logic.

# ─── Image Uploads ───────────────────────────────────────────────────────────
# Defaults to public/uploads/helmets inside the project directory.
# Override for VPS deployments where you want uploads on a persistent volume:
#   UPLOAD_DIR="/var/data/helmet-armoury/helmets"
#   UPLOAD_PUBLIC_PREFIX="https://your-domain.com/uploads/helmets"
# UPLOAD_DIR=
# UPLOAD_PUBLIC_PREFIX=
