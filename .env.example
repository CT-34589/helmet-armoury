DATABASE_URL="file:./dev.db"
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
# Must match the origin you use in the browser (pick one: localhost or 127.0.0.1) and your Discord redirect URL.
AUTH_URL="http://localhost:3000"
AUTH_DISCORD_ID="your-discord-app-client-id"
AUTH_DISCORD_SECRET="your-discord-app-client-secret"
NEXTAUTH_URL="http://localhost:3000"

# Discord guild/role for art team check
DISCORD_GUILD_ID="your-guild-id"
DISCORD_ART_TEAM_ROLE_ID="your-art-team-role-id"

# Discord webhook — evidence submissions posted here
DISCORD_EVIDENCE_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# KMC Discord rank roles — used for cooldown type calculation (comma-separated role IDs)
# SGM+ = Sergeant Major and above (Standard helmet → Custom cooldown tier)
KMC_SGM_PLUS_ROLE_IDS=
# Cadre = Cadre rank (Non-Standard helmet → Custom cooldown tier)
KMC_CADRE_ROLE_IDS=
# Head Cadre = Head Cadre rank (Non-Standard helmet → Custom cooldown tier)
KMC_HEAD_CADRE_ROLE_IDS=
# CT-SGT (Private through Sergeant) is the default — no env var needed

# Image upload storage (optional — defaults to public/uploads inside the project)
# Override to store uploads outside the web root on a VPS, e.g.:
#   UPLOAD_DIR="/var/data/helmet-armoury/uploads"
#   UPLOAD_PUBLIC_PREFIX="http://your-domain.com/uploads/helmets"
# UPLOAD_DIR=
# UPLOAD_PUBLIC_PREFIX=
